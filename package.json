{
  "name": "audio-loudness-pwa",
  "version": "0.2.8",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "lint": "eslint src --ext ts,tsx",
    "type-check": "tsc --noEmit",
    "deploy": "npm run build && wrangler pages deploy dist --project-name=audio-loudness-normalizer",
    "deploy:preview": "npm run build && wrangler pages deploy dist --project-name=audio-loudness-normalizer --branch=preview"
  },
  "dependencies": {
    "@ffmpeg/core-mt": "^0.12.6",
    "@ffmpeg/ffmpeg": "^0.12.6",
    "@ffmpeg/util": "^0.12.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-dropzone": "^14.2.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^20.10.6",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "@vitejs/plugin-react": "^4.2.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.8",
    "vitest": "^1.1.0",
    "workbox-cli": "^7.0.0",
    "workbox-window": "^7.0.0",
    "wrangler": "^3.114.17"
  }
}